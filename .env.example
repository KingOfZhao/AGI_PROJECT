# AGI v13.3 Cognitive Lattice - 环境变量配置模板
# 复制为 .env 并填入实际值

# ==================== 系统 ====================
AGI_ENV=development          # development | production | test
AGI_DEBUG=false
AGI_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# ==================== API服务 ====================
AGI_API_HOST=0.0.0.0
AGI_API_PORT=5002

# ==================== LLM后端 (敏感信息!) ====================
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# ==================== 安全 ====================
AGI_EXEC_TIMEOUT=30
AGI_MAX_TOKENS=8192
AGI_TEMPERATURE=0.35

# ==================== Redis缓存 ====================
REDIS_URL=redis://localhost:6379/0
