{
  "name": "shell_executor",
  "display_name": "Shell Executor - 命令行执行能力",
  "description": "让模型通过Python脚本安全执行命令行操作。支持：shell命令执行、Python代码/脚本执行、文件读写、进程管理、端口检查、HTTP请求、系统信息获取。所有操作通过subprocess安全执行，有超时保护和危险命令拦截。",
  "version": "1.0.0",
  "author": "AGI-实践器",
  "capabilities": [
    "run_shell - 执行shell命令",
    "run_python - 执行Python代码片段",
    "run_script - 执行Python脚本文件",
    "read_file - 读取文件",
    "write_file - 写入文件",
    "list_processes - 列出/过滤进程",
    "check_port - 检查端口状态",
    "http_get - HTTP GET请求",
    "system_info - 系统信息",
    "batch_run - 批量顺序执行命令"
  ],
  "usage_examples": [
    "from workspace.skills.shell_executor import run_shell; run_shell('ls -la')",
    "from workspace.skills.shell_executor import run_python; run_python('print(1+1)')",
    "from workspace.skills.shell_executor import check_port; check_port(5002)",
    "python workspace/skills/shell_executor.py run ls -la",
    "python workspace/skills/shell_executor.py port 5002",
    "python workspace/skills/shell_executor.py info"
  ],
  "safety": {
    "dangerous_keywords_blocked": ["rm -rf", "mkfs", "dd if=", "format", "> /dev/", "shutdown", "reboot"],
    "default_timeout": 30,
    "max_output_chars": 10000
  },
  "created_at": "2026-03-18"
}
